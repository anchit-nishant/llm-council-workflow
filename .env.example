# Provider credentials
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_API_BASE=http://localhost:11434

# Google Gemini backend selection
# gemini_api: Gemini Developer API using GEMINI_API_KEY or GOOGLE_API_KEY
# vertex_ai: Vertex AI using Application Default Credentials (ADC)
GOOGLE_GEMINI_BACKEND=gemini_api
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=us-central1

# Required default workflow model selection
# Fill these with real model identifiers before starting the app.
# Example:
# DEFAULT_COUNCIL_MODELS=gemini/gemini-2.5-pro,openai/gpt-4.1-mini,anthropic/claude-3-7-sonnet-latest,ollama/llama3.1:8b
# DEFAULT_SYNTHESIS_MODEL=gemini/gemini-2.5-pro
DEFAULT_COUNCIL_MODELS=
DEFAULT_SYNTHESIS_MODEL=
